{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "strict": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@pulse/api": ["../../packages/api/src/index.ts"],
      "@pulse/api/*": ["../../packages/api/src/*"],
      "@pulse/config": ["../../packages/config/src/index.ts"],
      "@pulse/config/*": ["../../packages/config/src/*"],
      "@pulse/ui": ["../../packages/ui/src/index.ts"],
      "@pulse/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "../../packages/api/src",
    "../../packages/config/src",
    "../../packages/ui/src"
  ],
  "exclude": ["dist", "node_modules"]
}
